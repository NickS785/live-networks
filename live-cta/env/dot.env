# --------------------------------------------------------------------------
# live-cta environment configuration
# Copy this file or rename to .env and fill in your values.
# --------------------------------------------------------------------------

# --- GCS (Google Cloud Storage) ---
GCS_BUCKET=ctaflow-prod-artifacts
GCS_PROJECT=
GCS_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=env/gcs_service_account.json

# --- Data paths (relative to project root) ---
MODEL_DATA_DIR=model_data/
INTRADAY_CSV=model_data/NG/intraday_2.csv
RESULTS_DIR=results/

# --- EIA / Weather cache ---
EIA_CACHE_DIR=model_data/
WEATHER_CACHE_DIR=model_data/

# --- API keys ---
EIA_API_KEY=
NCEI_TOKEN=

# --- IBKR ---
IBKR_BASE_URL=https://localhost:5000
IBKR_ACCOUNT_ID=
NG_CONID=

# --- S3 (optional, if using AWS instead of GCS) ---
S3_BUCKET=
S3_ENDPOINT=
S3_PREFIX=
